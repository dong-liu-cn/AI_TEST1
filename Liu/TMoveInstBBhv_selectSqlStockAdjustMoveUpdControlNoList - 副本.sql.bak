/*
 [df:title]
  在庫調整・在庫移動抽出対象の在庫移動指示ヘッダIDの取得

 [df:description]
  在庫調整・在庫移動抽出対象の在庫移動指示ヘッダIDを取得する
*/

-- #df:entity#

-- !df:pmb!
-- !!Long clientId!!
-- !!Long centerId!!
-- !!AutoDetect!!

SELECT
	DISTINCT(T_MOVE_INST_R.MOVE_INST_H_ID) AS MOVE_INST_H_ID
FROM
	T_MOVE_INST_R
JOIN
	T_MOVE_INST_H TH1
  ON T_MOVE_INST_R.MOVE_INST_H_ID = TH1.MOVE_INST_H_ID
JOIN
	(SELECT
		TM.MOVE_INST_H_ID,
		TM.MOVE_INST_B_ID,
		TM.TRANSFORM_CD,
		TM.TRANSFORM_CD_F
	FROM (
		SELECT
			TM1.MOVE_INST_H_ID,
			TM1.MOVE_INST_B_ID,
			TM1.LOCATION_ID,
			TM1.PROCESS_TYPE_CD,
			TM1.PRODUCT_CD,
			TM1.TRANSFORM_CD,
			TM1.STOCK_TYPE_CD,
			TM1.TRANSFORM_CD_F
		FROM (
				SELECT
					TMIB.MOVE_INST_H_ID,
					TMIB.MOVE_INST_B_ID,
					TMIB.LOCATION_ID,
					TMIB.PRODUCT_CD,
					TMIB.STOCK_TYPE_CD,
					MPT.PROCESS_TYPE_CD,
					MM.TRANSFORM_CD,
					MM2.TRANSFORM_CD AS TRANSFORM_CD_F
				FROM
					T_MOVE_INST_R TMIR
				JOIN
					T_MOVE_INST_H TMIH
				  ON TMIR.MOVE_INST_H_ID = TMIH.MOVE_INST_H_ID
				JOIN
					M_PROCESS_TYPE MPT
				  ON TMIH.PROCESS_TYPE_ID = MPT.PROCESS_TYPE_ID
				JOIN
					T_MOVE_INST_B TMIB
				  ON TMIH.MOVE_INST_H_ID= TMIB.MOVE_INST_H_ID
				LEFT OUTER JOIN
					T_MOVE_INST_B TMIB2
				  ON TMIH.MOVE_INST_H_ID= TMIB2.MOVE_INST_H_ID
				  AND TMIB.MOVE_INST_B_ID <> TMIB2.MOVE_INST_B_ID
				JOIN
					M_LOCATION ML
				  ON TMIB.LOCATION_ID = ML.LOCATION_ID
				LEFT OUTER JOIN
					M_LOCATION ML2
				  ON TMIB2.LOCATION_ID = ML2.LOCATION_ID
				JOIN
					M_ZONE MZ
				  ON ML.ZONE_ID = MZ.ZONE_ID
				LEFT OUTER JOIN
					M_ZONE MZ2
				  ON ML2.ZONE_ID = MZ2.ZONE_ID
				JOIN
					M_WAREHOUSE MW
				  ON MZ.WAREHOUSE_ID = MW.WAREHOUSE_ID
				LEFT OUTER JOIN
					M_WAREHOUSE MW2
				  ON MZ2.WAREHOUSE_ID = MW2.WAREHOUSE_ID
				LEFT JOIN
					(
					SELECT
						TRANSFORM_CD,
						MATCHING_KEYWORD
					FROM
						M_MATCHING
					WHERE
						MATCHING_TYPE = 'StockAdjustMoveWH'
					)MM
				  ON MM.MATCHING_KEYWORD = MW.WAREHOUSE_CD
				LEFT JOIN
					(
					SELECT
						TRANSFORM_CD,
						MATCHING_KEYWORD
					FROM
						M_MATCHING
					WHERE
						MATCHING_TYPE = 'StockAdjustMoveWH'
					)MM2
				  ON MM2.MATCHING_KEYWORD = MW2.WAREHOUSE_CD
			)TM1
		WHERE 1 = 1
		/*IF pmb.isStockDataFlg == true*/
		AND (TM1.PROCESS_TYPE_CD IN /*pmb.processTypeCdMove*/('21','29')
		AND TM1.TRANSFORM_CD <> TM1.TRANSFORM_CD_F)
		OR  TM1.PROCESS_TYPE_CD IN /*pmb.processTypeCdAdj*/('23','24')
		/*END*/
		/*IF pmb.isStockDataFlg == false*/
		AND (TM1.PROCESS_TYPE_CD IN /*pmb.processTypeCdDepot*/('25')
		AND TM1.TRANSFORM_CD <> TM1.TRANSFORM_CD_F)
		/*END*/
		) TM
	) TMB
ON TH1.MOVE_INST_H_ID = TMB.MOVE_INST_H_ID
JOIN T_MOVE_RECORD_B
  ON TMB.MOVE_INST_B_ID = T_MOVE_RECORD_B.MOVE_INST_B_ID
JOIN T_STOCK_INOUT
  ON T_MOVE_RECORD_B.MOVE_RECORD_B_ID = T_STOCK_INOUT.MOVE_RECORD_B_ID
WHERE 1 = 1
/*IF pmb.clientId != null*/
AND TH1.CLIENT_ID = /*pmb.clientId*/1
/*END*/
/*IF pmb.centerId != null*/
AND TH1.CENTER_ID = /*pmb.centerId*/1
/*END*/
/*IF pmb.stockRecordOutDtF != null*/
AND T_MOVE_INST_R.STOCK_RECORD_OUT_DT >= /*pmb.stockRecordOutDtF*/'2023-02-20'
AND T_MOVE_INST_R.STOCK_RECORD_OUT_DT < /*pmb.stockRecordOutDtT*/'2023-02-21'
/*END*/
AND
( T_MOVE_INST_R.STOCK_RECORD_OUT_FLG = /*pmb.stockRecordOutFlg*/'1'
/*IF pmb.stockRecordOutFlg == '0'*/
OR
T_MOVE_INST_R.STOCK_RECORD_OUT_FLG IS NULL
/*END*/
)
/*IF pmb.isStockDataFlg == true*/
AND TH1.STOCK_ADJ_REC_NOT_FLG = '0'
AND TH1.MOVE_INST_STATUS = '02'
/*END*/
/*IF pmb.receiptAndInventoryResultLinkedFlag == '1'*/
AND T_STOCK_INOUT.STOCK_OUT_CONTROL_FLG IS NOT NULL
/*END*/