      "precondition": [
        "出力ボタン押下時、取引先コード・選別数集計基準日の必須チェックを行う",
        "出力ボタン押下時、選別数集計基準日の未来日チェック（営業日と比較）を行う"
      ],
      "supplement": [
        "ログインユーザの所属会社・ロケールにかかわらず、Webデポ同様の設定（会社コード＝\"100\"、ロケール＝\"ja\"）で各種名称を取得する",
        "Excelテンプレートも同様に日本語版のみとする",
        "検索基準日（実績済在庫基準日）以前で最も近い在庫日報を出力する"
      ],
      "sortOrder": [],
      "postAction": "「在庫日報」のExcelファイルが作成される",
      "completionAction": "発行処理完了の確認メッセージを表示する"
    }
