      "trigger": "「検索」ボタン押下",
      "actionId": "①",
      "layer": "frontend/backend",
      "description": "検索条件に従い、在庫情報を取得する",
      "precondition": "無し",
      "supplement": [
        "検索処理の詳細について、「設計概要①_概要補足」シートの＜１．検索結果について＞を参照する",
        "実績済在庫基準日と予定在庫基準日に従う在庫数の表示について、「設計概要②_在庫の見え方」を参照する"
      ],
      "sortOrder": [
        { "no": 1, "field": "組織コード", "remarks": "コードマスタに設定している優先表示組織（1300、1303）の情報を一覧の先頭に表示する" },
        { "no": 2, "field": "取引先コード", "remarks": "" },
        { "no": 3, "field": "品目コード", "remarks": "" }
      ],
      "postAction": "在庫情報のデータを取得し、明細画面を表示する",
      "completionAction": "無し"
    },
    {
      "processNo": 2,
      "processName": "Excel出力処理",
      "trigger": "「Excel」ボタン押下",
      "actionId": "②",
      "layer": "frontend/backend",
      "description": "検索結果一覧をExcelで出力する",
      "precondition": "検索結果が一覧表示されていること",
      "supplement": ["詳細は別紙の共通設計書を参照"],
      "sortOrder": [{ "no": 1, "field": "「検索」ボタン押下時と同じ", "remarks": "" }],
      "postAction": "検索結果の一覧をExcel出力する",
      "completionAction": "出力処理完了の確認メッセージを表示する"
    },
    {
      "processNo": 3,
      "processName": "ページング制御処理",
